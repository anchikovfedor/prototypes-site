{
  "name": "prototypes",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Кликабельные прототипы на React + VKUI: демонстрация анимаций и переходов между экранами",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev -w apps/index",
    "build": "npm run build --workspaces --if-present",
    "build:site": "node scripts/build-site.mjs",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "prettier": "^3.9.4",
    "typescript": "^5.7.0",
    "vite": "^8.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
